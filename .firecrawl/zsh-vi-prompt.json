  If you dont want to use additional zsh plugins, you can use this small code piece to detect INSERT, NORMAL, VISUAL, V-LINE and REPLACE modes:
  
  ```bash
  Copy
  case "${KEYMAP}" in
      vicmd)
          case "${REGION_ACTIVE}" in
              1)
                  VI_KEYMAP="VISUAL"
                  ;;
              2)
                  VI_KEYMAP="V-LINE"
                  ;;
              *)
                  VI_KEYMAP="NORMAL"
                  ;;
          esac
          ;;
      viins|main)
          if [[ "${ZLE_STATE}" == *overwrite* ]]; then
              VI_KEYMAP="REPLACE"
          else
              VI_KEYMAP="INSERT"
          fi
          ;;
  esac
  ```
  
  You can add a line pre-redraw hook to update the PROMPT string every time the key map changes:
  
  ```bash
  Copy
  autoload -U add-zle-hook-widget
  
  function line_pre_redraw {
      local previous_vi_keymap="${VI_KEYMAP}"
  
      case "${KEYMAP}" in
          vicmd)
              case "${REGION_ACTIVE}" in
                  1)
                      VI_KEYMAP="VISUAL"
                      ;;
                  2)
                      VI_KEYMAP="V-LINE"
                      ;;
                  *)
                      VI_KEYMAP="NORMAL"
                      ;;
              esac
              ;;
          viins|main)
              if [[ "${ZLE_STATE}" == *overwrite* ]]; then
                  VI_KEYMAP="REPLACE"
              else
                  VI_KEYMAP="INSERT"
              fi
              ;;
      esac
  
      if [[ "${VI_KEYMAP}" != "${previous_vi_keymap}" ]]; then
          zle reset-prompt
      fi
  
  }
  add-zle-hook-widget zle-line-pre-redraw line_pre_redraw
  ```
  
  See my zsh theme for a full example with changing cursor shapes and a prompt mode indicator: [https://github.com/IngoMeyer441/steeef](https://github.com/IngoMeyer441/steeef).
  
